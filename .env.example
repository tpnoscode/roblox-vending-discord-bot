# Discord Configuration
# Get these from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Roblox Configuration
# For automated item delivery and group management
ROBLOX_API_KEY=
ROBLOX_GROUP_ID=

# Payment Configuration (Auto-charge)
# Details for bank transfer or other payment methods
BANK_ACCOUNT_NUMBER=
BANK_NAME=
PAYMENT_API_KEY=

# Bot Admin Settings
OWNER_DISCORD_ID=
ADMIN_ROLE_ID=

# Antigravity Hosting Configuration
# Recommended for 24/7 operation using Scheduled Tasks
# Spec: seconds minutes hours day-of-month month day-of-week
ANTIGRAVITY_CRON="0 */15 * * * *"

# Database Configuration (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres
